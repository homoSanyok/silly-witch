{
    "$schema": "https://github.com/homoSanyok/silly-witch/tree/main/public/actions",
    "title": "Action results map",
    "type": "object",
    "properties": {
        "success": {
            "type": "object",
            "description": "Результаты успешных взаимодействий",
            "additionalProperties": {
                "$ref": "#/definitions/ActionT"
            },
            "minProperties": 1,
            "errorMessage": {
                "minProperties": "Секция 'success' должна содержать хотя бы одно действие"
            }
        },
        "failed": {
            "type": "object",
            "description": "Результаты проваленных взаимодействий",
            "additionalProperties": {
                "$ref": "#/definitions/ActionT"
            },
            "minProperties": 1,
            "errorMessage": {
                "minProperties": "Секция 'failed' должна содержать хотя бы одно действие"
            }
        }
    },
    "required": [
        "success",
        "failed"
    ],
    "additionalProperties": false,
    "definitions": {
        "ActionT": {
            "type": "object",
            "description": "Результат действия",
            "properties": {
                "foolishness": {
                    "type": "integer",
                    "description": "Количество дурости, на которое изменится шкала дурости в момент совершения действия",
                    "minimum": -100,
                    "maximum": 100
                },
                "stupidity": {
                    "type": "integer",
                    "description": "Количество глупости, на которое изменится шакала глупости в кноце дня",
                    "minimum": -100,
                    "maximum": 100
                },
                "chance": {
                    "type": "float",
                    "description": "Вероятность того, что выпадет именно это действие",
                    "minimum": 0,
                    "maximum": 1
                },
                "minFoolishness": {
                    "type": "integer",
                    "description": "Минимальное кол-во дурости, при котором действие может быть совершено",
                    "minimum": 0,
                    "maximum": 100
                },
                "maxFoolishness": {
                    "type": "integer",
                    "description": "максимальное кол-во дурости, при котором действие может быть совершено",
                    "minimum": 0,
                    "maximum": 100
                },
                "title": {
                    "type": "string",
                    "description": "Название действия",
                    "minLength": 1
                },
                "description": {
                    "type": "string",
                    "description": "Описание действия",
                    "minLength": 1
                }
            },
            "required": [
                "foolishness",
                "description"
            ],
            "additionalProperties": false
        }
    }
}